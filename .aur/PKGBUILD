# Maintainer: Y.K. Goon
# AUR Package for ClickDown - A fast and responsive ClickUp terminal client
pkgname=clickdown-bin
pkgver=0.2.0
pkgrel=1
pkgdesc="A fast and responsive ClickUp desktop client for the terminal"
arch=('x86_64')
url="https://github.com/ykgoon/clickdown"
license=('MIT')
depends=('glibc' 'openssl')
optdepends=('gtk3: for desktop integration')
provides=('clickdown')
conflicts=('clickdown')
source_x86_64=("${pkgname}-${pkgver}::https://github.com/ykgoon/clickdown/releases/download/v${pkgver}/clickdown-linux-x86_64")
sha256sums_x86_64=('SKIP')

package() {
  # Install binary
  install -Dm755 "${srcdir}/${pkgname}-${pkgver}" "${pkgdir}/usr/bin/clickdown"

  # Install license file
  install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Install desktop entry
  install -Dm644 "${srcdir}/clickdown.desktop" "${pkgdir}/usr/share/applications/clickdown.desktop"

  # Install icon (if available)
  if [ -f "${srcdir}/clickdown.png" ]; then
    install -Dm644 "${srcdir}/clickdown.png" "${pkgdir}/usr/share/pixmaps/clickdown.png"
  fi
}
